{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://debugd.dev/schema/trace.schema.json",
  "title": "debugd trace envelope v1",
  "type": "object",
  "required": ["v", "trace_id", "app", "request", "queries", "logs"],
  "properties": {
    "v": { "const": 1 },
    "trace_id": { "type": "string" },
    "app": { "type": "string" },
    "project_root": { "type": "string" },
    "request": {
      "type": "object",
      "required": ["method", "path", "status", "duration_ms"],
      "properties": {
        "method": { "type": "string" },
        "path": { "type": "string" },
        "route": { "type": "string" },
        "status": { "type": "integer" },
        "duration_ms": { "type": "number" },
        "boot_ms": { "type": "number" },
        "memory_mb": { "type": "number" },
        "started_at": { "type": "string" }
      }
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sql", "bindings_count", "duration_ms", "connection", "caller", "offset_ms"],
        "properties": {
          "sql": { "type": "string" },
          "bindings_count": { "type": "integer" },
          "duration_ms": { "type": "number" },
          "connection": { "type": "string" },
          "caller": { "type": "string" },
          "offset_ms": { "type": "number" }
        }
      }
    },
    "logs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "message", "offset_ms"],
        "properties": {
          "level": { "type": "string" },
          "message": { "type": "string" },
          "context": { "type": "object" },
          "offset_ms": { "type": "number" }
        }
      }
    },
    "dumps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["value", "caller", "offset_ms"],
        "properties": {
          "label": { "type": ["string", "null"] },
          "type": { "type": "string" },
          "value": { "type": "string" },
          "caller": { "type": "string" },
          "offset_ms": { "type": "number" }
        }
      }
    },
    "measures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "duration_ms", "offset_ms"],
        "properties": {
          "label": { "type": "string" },
          "duration_ms": { "type": "number" },
          "caller": { "type": "string" },
          "offset_ms": { "type": "number" },
          "concurrent": { "type": "boolean" },
          "group": { "type": "string" }
        }
      }
    },
    "octane": {
      "type": ["object", "null"],
      "properties": {
        "running": { "type": "boolean" },
        "worker_pid": { "type": "integer" },
        "worker_requests": { "type": "integer" },
        "worker_memory_start_mb": { "type": "number" },
        "memory_growth_mb": { "type": "number" },
        "bindings": { "type": "integer" },
        "new_bindings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "exception": {
      "type": ["object", "null"],
      "properties": {
        "class": { "type": "string" },
        "message": { "type": "string" },
        "file": { "type": "string" },
        "trace": { "type": "string" }
      }
    }
  }
}
