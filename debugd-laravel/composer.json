{
  "name": "debugd/debugd-laravel",
  "description": "Zero-instrumentation request tracing for Laravel — passive collector for the debugd server.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0 || ^12.0 || ^13.0",
    "guzzlehttp/guzzle": "^7.8",
    "symfony/uid": "^7.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0 || ^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0",
    "opis/json-schema": "^2.6"
  },
  "autoload": {
    "psr-4": { "Debugd\\": "src/" },
    "files": ["src/helpers.php"]
  },
  "autoload-dev": {
    "psr-4": { "Debugd\\Tests\\": "tests/" }
  },
  "extra": {
    "laravel": {
      "providers": ["Debugd\\DebugdServiceProvider"]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": { "pestphp/pest-plugin": true }
  }
}
